{
  "name": "shanghai-hs-math-teaching-aids",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate:content && vite --config apps/web/vite.config.js --host 127.0.0.1",
    "build": "npm run generate:content && vite build --config apps/web/vite.config.js",
    "preview": "vite preview --config apps/web/vite.config.js --host 127.0.0.1",
    "generate:content": "node apps/web/scripts/generate-content-data.js",
    "generate:backlog": "node scripts/generate-resource-backlog.js",
    "scaffold:backlog": "node scripts/scaffold-resource-packages.js",
    "validate:content": "node scripts/validate-content.js",
    "test": "node --test apps/web/src/lib/content.test.js scripts/validate-content.test.js scripts/generate-resource-backlog.test.js scripts/scaffold-resource-packages.test.js",
    "verify": "npm run validate:content && npm run generate:backlog && npm run test && npm run build"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "vite": "^8.0.10"
  }
}
