{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EasonZhangyichen/shanghai-hs-math-teaching-aids/packages/applet-sdk/schemas/applet-metadata.schema.json",
  "title": "Shanghai High School Math Applet Metadata",
  "description": "Metadata contract for HTML applet resource packages in the Shanghai high school math teaching aids project.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "status",
    "resource_type",
    "title",
    "curriculum",
    "pedagogy",
    "mathematical_scope",
    "representations",
    "interaction_design",
    "data_contract",
    "feedback_and_diagnosis",
    "visual_semantics",
    "implementation",
    "files",
    "compliance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "id": {
      "type": "string",
      "pattern": "^SH-HS-MATH-HJ-(?:B[0-9]+|XB[0-9]+)-C[0-9]{2}-L[0-9]{2}-A[0-9]{2}$"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "status": {
      "$ref": "#/$defs/resourceStatus"
    },
    "resource_type": {
      "const": "applet"
    },
    "title": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "subtitle": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "curriculum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "region",
        "stage",
        "subject",
        "edition",
        "volume_id",
        "volume_title",
        "chapter_id",
        "chapter_title",
        "section_id",
        "section_title",
        "lesson_id",
        "textbook_ref",
        "lesson_title"
      ],
      "properties": {
        "region": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "stage": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "subject": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "edition": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "volume_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "volume_title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "chapter_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "chapter_title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "section_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "section_title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "lesson_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "textbook_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "lesson_title": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "pedagogy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cognitive_action",
        "estimated_classroom_minutes",
        "primary_teaching_problem",
        "learning_goals",
        "prerequisites",
        "successors",
        "core_competencies"
      ],
      "properties": {
        "cognitive_action": {
          "$ref": "#/$defs/cognitiveAction"
        },
        "estimated_classroom_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 90
        },
        "primary_teaching_problem": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "learning_goals": {
          "$ref": "#/$defs/stringArray"
        },
        "prerequisites": {
          "$ref": "#/$defs/stringArray"
        },
        "successors": {
          "$ref": "#/$defs/stringArray"
        },
        "core_competencies": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "mathematical_scope": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/metadataValue"
      },
      "properties": {
        "function": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "independent_variable": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dependent_variable": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "default_theta_range": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "extension_theta_range": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "key_angles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/$defs/metadataValue"
            }
          }
        },
        "out_of_scope": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "representations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "role"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/snakeCaseId"
          },
          "role": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "interaction_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_control",
        "teacher_controls",
        "staged_reveal"
      ],
      "properties": {
        "primary_control": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "teacher_controls": {
          "$ref": "#/$defs/stringArray"
        },
        "student_controls": {
          "$ref": "#/$defs/stringArray"
        },
        "staged_reveal": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step",
              "description"
            ],
            "properties": {
              "step": {
                "$ref": "#/$defs/snakeCaseId"
              },
              "description": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        }
      }
    },
    "data_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_variables",
        "events"
      ],
      "properties": {
        "state_variables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "description"
            ],
            "properties": {
              "name": {
                "$ref": "#/$defs/snakeCaseId"
              },
              "unit": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "value_type": {
                "enum": [
                  "number",
                  "boolean",
                  "string",
                  "point2d",
                  "array",
                  "object"
                ]
              },
              "default": {
                "$ref": "#/$defs/metadataValue"
              },
              "description": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "persistence": {
                "enum": [
                  "session",
                  "snapshot",
                  "none"
                ]
              }
            }
          }
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "payload"
            ],
            "properties": {
              "name": {
                "$ref": "#/$defs/snakeCaseId"
              },
              "direction": {
                "enum": [
                  "applet_to_player",
                  "player_to_applet",
                  "internal"
                ]
              },
              "description": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "payload": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/snakeCaseId"
                },
                "uniqueItems": true
              },
              "required_for_player": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "feedback_and_diagnosis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "success_evidence",
        "common_error_tags",
        "feedback_principles"
      ],
      "properties": {
        "success_evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "common_error_tags": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "label"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/snakeCaseId"
              },
              "label": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        },
        "feedback_principles": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "visual_semantics": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "html_src_status",
        "planned_engine",
        "classroom_device_targets"
      ],
      "properties": {
        "phase": {
          "enum": [
            "content_spec_only",
            "runnable_prototype",
            "review_candidate",
            "classroom_ready",
            "archived"
          ]
        },
        "html_src_status": {
          "enum": [
            "not_started",
            "scaffolded",
            "runnable",
            "interaction_verified",
            "archived"
          ]
        },
        "planned_engine": {
          "enum": [
            "native-canvas-svg",
            "jsxgraph",
            "geogebra",
            "cindyjs",
            "d3",
            "threejs",
            "other"
          ]
        },
        "create_src_in_later_task": {
          "type": "boolean"
        },
        "required_future_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/filePath"
          }
        },
        "classroom_device_targets": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readme",
        "teacher_script",
        "student_task",
        "review_record"
      ],
      "properties": {
        "readme": {
          "$ref": "#/$defs/filePath"
        },
        "teacher_script": {
          "$ref": "#/$defs/filePath"
        },
        "student_task": {
          "$ref": "#/$defs/filePath"
        },
        "review_record": {
          "$ref": "#/$defs/filePath"
        },
        "src_entry": {
          "$ref": "#/$defs/filePath"
        }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "copyright_note",
        "review_status"
      ],
      "properties": {
        "copyright_note": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "review_status": {
          "enum": [
            "self_checked_draft",
            "math_review_pending",
            "math_review_passed",
            "pedagogy_review_pending",
            "pedagogy_review_passed",
            "classroom_trial_ready",
            "stable_approved",
            "deprecated"
          ]
        }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "resourceStatus": {
      "enum": [
        "draft",
        "math_review",
        "pedagogy_review",
        "classroom_trial",
        "stable",
        "deprecated"
      ]
    },
    "cognitiveAction": {
      "enum": [
        "比较",
        "分解",
        "变换",
        "逼近",
        "累积",
        "缩放",
        "投影",
        "模拟"
      ]
    },
    "snakeCaseId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "filePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\\\]+$"
    },
    "metadataValue": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array"
        },
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
